# Vocalis Backend Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================================================
# Database Configuration
# ============================================================================

# Database URL for local development (SQLite)
# For PostgreSQL production: postgresql://user:password@localhost/vocalis
DATABASE_URL=sqlite:///./vocalis.db

# ============================================================================
# JWT Configuration
# ============================================================================

# SECURITY CRITICAL: Secret key for signing JWT tokens
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This MUST be set in production - defaults are for development only
JWT_SECRET=your-secret-key-change-in-production

# JWT token expiration time in hours
JWT_EXPIRATION_HOURS=24

# ============================================================================
# CORS Configuration
# ============================================================================

# SECURITY CRITICAL: Allowed origins for CORS requests (comma-separated)
# Format: http://localhost:3000,https://example.com,https://api.example.com
#
# Development (default if not set):
#   - http://localhost:3000
#   - http://localhost:8080
#   - http://127.0.0.1:3000
#   - http://127.0.0.1:8080
#   - http://localhost:5900 (Flutter web)
#   - http://127.0.0.1:5900 (Flutter web)
#
# Production examples:
#   CORS_ORIGINS=https://app.example.com
#   CORS_ORIGINS=https://app.example.com,https://www.example.com
#   CORS_ORIGINS=https://app.example.com,https://api.example.com,https://admin.example.com
#
# IMPORTANT: Only set HTTPS origins in production to prevent MITM attacks
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000

# ============================================================================
# Ollama Configuration
# ============================================================================

# Base URL for Ollama server (LLM inference)
OLLAMA_BASE_URL=http://localhost:11434

# Model name to use with Ollama
OLLAMA_MODEL=mistral

# Ollama request timeout in seconds
OLLAMA_TIMEOUT=120

# ============================================================================
# SQL Configuration
# ============================================================================

# Enable SQL query logging (true/false)
# WARNING: Only use in development - logs sensitive data
SQL_DEBUG=false
